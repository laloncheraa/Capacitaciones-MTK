import streamlit as st
import pandas as pd

# Título
st.title("🚀 Mi primer dashboard")

# Datos de prueba
data = {
    "Region": ["Norte", "Sur", "Centro", "Norte", "Sur"],
    "Status": ["Aprobado", "Reprobado", "Pendiente", "Aprobado", "Pendiente"]
}

df = pd.DataFrame(data)

# Filtro tipo slicer
region = st.selectbox("Selecciona Región", df["Region"].unique())

df_filtrado = df[df["Region"] == region]

# Métricas
st.subheader("Resultados")
st.write(df_filtrado)

# Gráfica
st.bar_chart(df_filtrado["Status"].value_counts())
